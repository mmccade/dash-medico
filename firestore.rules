rules_version = '2';
// ============================================================
// SECURITY RULES — Murev Acompanha (atualizado)
// Alterações:
//  - Audit logs: admin pode escrever em audit_logs
//  - Soft-delete: campo excluido tratado pela app, não pelas rules
//  - Leitura de perfil agora verifica se excluido != true
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'souzasoaresgabrie9@gmail.com';
    }

    function isDono(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Perfil do usuário: usuarios/{uid}
    match /usuarios/{uid} {
      allow read:   if isDono(uid) || isAdmin();
      allow create: if isDono(uid) || isAdmin();
      allow update: if isDono(uid) || isAdmin();
      allow delete: if false; // soft-delete apenas

      // Pacientes: só o dono acessa
      match /pacientes/{pid} {
        allow read, write: if isDono(uid);
      }
    }

    // Audit log: admin escreve, ninguém mais lê (só via Console Firebase)
    match /audit_logs/{logId} {
      allow create: if isAdmin();
      allow read:   if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
