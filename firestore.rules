rules_version = '2';
// ============================================================
// SECURITY RULES — Murev Acompanha
// Alteração: admin agora pode LER pacientes (só leitura) para mostrar
// contagem no painel administrativo. Escrita continua só do dono.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'souzasoaresgabrie9@gmail.com';
    }

    function isDono(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Perfil do usuário: usuarios/{uid}
    match /usuarios/{uid} {
      allow read:   if isDono(uid) || isAdmin();
      allow create: if isDono(uid) || isAdmin();
      allow update: if isDono(uid) || isAdmin();
      allow delete: if false;

      // Pacientes — dono escreve e lê; admin SÓ lê (pra contar)
      match /pacientes/{pid} {
        allow read:  if isDono(uid) || isAdmin();
        allow write: if isDono(uid);
      }
    }

    // Audit log
    match /audit_logs/{logId} {
      allow create: if isAdmin();
      allow read:   if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
