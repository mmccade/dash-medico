rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'souzasoaresgabrie9@gmail.com';
    }
    function isDono(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    function naoMexeEmCamposDeAssinatura() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['status', 'statusAssinatura', 'plano', 'acessoAte',
                 'planoDesde', 'pausadoEm', 'motivoPausa',
                 'stripeCustomerId', 'stripeSubscriptionId',
                 'excluido', 'origem']);
    }
    function donoAtivo(database, uid) {
      return isDono(uid)
        && (
          !exists(/databases/$(database)/documents/usuarios/$(uid))
          || !('status' in get(/databases/$(database)/documents/usuarios/$(uid)).data)
          || get(/databases/$(database)/documents/usuarios/$(uid)).data.status != 'pausado'
        );
    }
    match /usuarios/{uid} {
      allow read:   if isDono(uid) || isAdmin();
      allow create: if isDono(uid) || isAdmin();
      allow update: if isAdmin()
                    || (isDono(uid) && naoMexeEmCamposDeAssinatura());
      allow delete: if false;

      match /pacientes/{pid} {
        allow read:  if isDono(uid) || isAdmin();
        allow write: if donoAtivo(database, uid);
      }
    }
    match /audit_logs/{logId} {
      allow create: if isAdmin();
      allow read:   if false;
      allow update: if false;
      allow delete: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
